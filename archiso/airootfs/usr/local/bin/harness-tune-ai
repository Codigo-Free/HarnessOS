#!/usr/bin/env python3
"""harness-tune-ai — Pick the best local AI models for this machine.

Detects GPU VRAM (NVIDIA/AMD) and system RAM, then writes the model
routing table to ~/.config/harness/config.toml [models] so harness-ai,
and anything else reading that file, uses models this hardware can run.

Run automatically by harness-online-setup on first boot; safe to re-run
manually after a hardware change (use --force to overwrite your config).
"""
from __future__ import annotations

import argparse
import subprocess
import sys
import tomllib
from pathlib import Path

CONFIG_FILE = Path.home() / ".config" / "harness" / "config.toml"

# Tiers: (min VRAM MiB, min RAM MiB if no dGPU) → model table.
# CPU-only inference needs ~2x the memory headroom, hence higher RAM floors.
TIERS = [
    ("high", 20_000, 49_152, {
        "default": "llama3.2",
        "code":    "qwen3:27b",
        "doctor":  "deepseek-r1:14b",
        "explain": "gemma3:12b",
        "commit":  "qwen2.5-coder:7b",
        "logs":    "deepseek-r1:14b",
    }),
    ("mid", 10_000, 28_672, {
        "default": "llama3.2",
        "code":    "qwen2.5-coder:14b",
        "doctor":  "deepseek-r1:14b",
        "explain": "llama3.2",
        "commit":  "qwen2.5-coder:7b",
        "logs":    "deepseek-r1:7b",
    }),
    ("base", 5_000, 14_336, {
        "default": "llama3.2",
        "code":    "qwen2.5-coder:7b",
        "doctor":  "deepseek-r1:7b",
        "explain": "llama3.2",
        "commit":  "qwen2.5-coder:7b",
        "logs":    "deepseek-r1:7b",
    }),
    ("low", 0, 0, {
        "default": "llama3.2",
        "code":    "qwen2.5-coder:3b",
        "doctor":  "llama3.2",
        "explain": "llama3.2",
        "commit":  "qwen2.5-coder:3b",
        "logs":    "llama3.2",
    }),
]


def _detect_vram_mib() -> int:
    """Dedicated GPU VRAM in MiB, or 0 if only an iGPU / no GPU."""
    try:
        out = subprocess.run(
            ["nvidia-smi", "--query-gpu=memory.total", "--format=csv,noheader,nounits"],
            capture_output=True, text=True, timeout=5,
        )
        if out.returncode == 0 and out.stdout.strip():
            return max(int(v) for v in out.stdout.split() if v.isdigit())
    except Exception:
        pass
    # AMD dGPU: sysfs reports bytes
    best = 0
    for f in Path("/sys/class/drm").glob("card*/device/mem_info_vram_total"):
        try:
            best = max(best, int(f.read_text()) // (1024 * 1024))
        except Exception:
            continue
    return best


def _detect_ram_mib() -> int:
    for line in Path("/proc/meminfo").read_text().splitlines():
        if line.startswith("MemTotal:"):
            return int(line.split()[1]) // 1024
    return 0


def _pick_tier(vram: int, ram: int) -> tuple[str, dict[str, str]]:
    for name, min_vram, min_ram, models in TIERS:
        if (min_vram and vram >= min_vram) or (min_ram and ram >= min_ram):
            return name, models
    return TIERS[-1][0], TIERS[-1][3]


def main() -> None:
    p = argparse.ArgumentParser(prog="harness-tune-ai", description=__doc__)
    p.add_argument("--force", action="store_true",
                   help="Overwrite an existing [models] section")
    p.add_argument("--dry-run", action="store_true",
                   help="Show what would be written without touching the config")
    p.add_argument("--print-pull", action="store_true",
                   help="Print the models worth pre-pulling (space-separated) and exit")
    args = p.parse_args()

    vram = _detect_vram_mib()
    ram = _detect_ram_mib()
    tier, models = _pick_tier(vram, ram)

    if args.print_pull:
        # Chat + code cover ~90% of use; the rest pull lazily on first use.
        print(" ".join(dict.fromkeys([models["default"], models["code"]])))
        return

    print(f"Hardware : VRAM {vram} MiB, RAM {ram} MiB → tier '{tier}'")

    if CONFIG_FILE.exists() and not args.force:
        try:
            existing = tomllib.loads(CONFIG_FILE.read_text())
        except tomllib.TOMLDecodeError:
            existing = {}
        if existing.get("models"):
            print(f"{CONFIG_FILE} already has [models] — keeping it (use --force to overwrite).")
            return

    lines = [
        "# Generated by harness-tune-ai — model routing for this hardware.",
        f"# Detected: {vram} MiB VRAM, {ram} MiB RAM (tier: {tier})",
        "# Edit freely; harness-ai and friends read this file.",
        "",
        "[models]",
    ]
    lines += [f'{mode} = "{model}"' for mode, model in models.items()]
    content = "\n".join(lines) + "\n"

    if args.dry_run:
        print(content)
        return

    CONFIG_FILE.parent.mkdir(parents=True, exist_ok=True)
    CONFIG_FILE.write_text(content)
    print(f"Wrote {CONFIG_FILE}:")
    for mode, model in models.items():
        print(f"  {mode:<8} → {model}")


if __name__ == "__main__":
    main()
