{
    "layer": "top",
    "position": "top",
    "height": 44,
    "exclusive": true,
    "passthrough": false,
    "modules-left": [
        "custom/logo",
        "hyprland/workspaces"
    ],
    "modules-center": [],
    "modules-right": [
        "network",
        "custom/browser",
        "custom/terminal",
        "custom/code",
        "custom/claude",
        "custom/power"
    ],
    "custom/logo": {
        "format": "⬡ HarnessOS",
        "tooltip": "App Launcher",
        "on-click": "wofi --show drun"
    },
    "hyprland/workspaces": {
        "format": "{id}",
        "on-click": "activate",
        "sort-by-number": true,
        "persistent-workspaces": {
            "*": [
                1,
                2,
                3,
                4
            ]
        }
    },
    "network": {
        "format-wifi": " {essid}",
        "format-ethernet": " LAN",
        "format-disconnected": "狼 Sin red",
        "tooltip-format-wifi": "WiFi: {essid}\nSeñal: {signalStrength}%\nIP: {ipaddr}",
        "tooltip-format-ethernet": "Ethernet\nIP: {ipaddr}",
        "tooltip-format-disconnected": "Sin conexión de red",
        "on-click": "kitty -e nmtui"
    },
    "custom/browser": {
        "format": "",
        "tooltip": "Firefox  (Super+B)",
        "on-click": "firefox"
    },
    "custom/terminal": {
        "format": "",
        "tooltip": "Terminal  (Super+Return)",
        "on-click": "kitty"
    },
    "custom/code": {
        "format": "",
        "tooltip": "VS Code  (Super+E)",
        "on-click": "code"
    },
    "custom/claude": {
        "format": "",
        "tooltip": "Claude AI  (Super+C)",
        "on-click": "kitty -e claude"
    },
    "custom/power": {
        "format": "",
        "tooltip": "Apagar / Reiniciar / Suspender",
        "on-click": "harness-power"
    }
}
