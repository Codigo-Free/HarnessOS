{
    "layer": "top",
    "position": "left",
    "width": 56,
    "exclusive": true,
    "passthrough": false,
    "modules-top": [
        "custom/logo",
        "hyprland/workspaces"
    ],
    "modules-center": [],
    "modules-bottom": [
        "custom/browser",
        "custom/terminal",
        "custom/code",
        "custom/claude",
        "custom/power"
    ],

    "custom/logo": {
        "format": "H",
        "tooltip": "HarnessOS — App Launcher",
        "on-click": "wofi --show drun"
    },

    "hyprland/workspaces": {
        "format": "{id}",
        "on-click": "activate",
        "sort-by-number": true,
        "active-only": false,
        "all-outputs": true
    },

    "custom/browser": {
        "format": "",
        "tooltip": "Firefox",
        "on-click": "firefox"
    },

    "custom/terminal": {
        "format": "",
        "tooltip": "Terminal",
        "on-click": "kitty"
    },

    "custom/code": {
        "format": "",
        "tooltip": "VS Code",
        "on-click": "code"
    },

    "custom/claude": {
        "format": "",
        "tooltip": "Claude AI",
        "on-click": "kitty -e claude"
    },

    "custom/power": {
        "format": "",
        "tooltip": "Apagar / Reiniciar",
        "on-click": "bash -c 'echo -e \"Apagar\\nReiniciar\\nSuspender\" | wofi --dmenu -p \"Sistema\" | xargs -I{} bash -c \"[ \\\"{}\\\" = Apagar ] && systemctl poweroff; [ \\\"{}\\\" = Reiniciar ] && systemctl reboot; [ \\\"{}\\\" = Suspender ] && systemctl suspend\"'"
    }
}
