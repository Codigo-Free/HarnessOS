[core]
    autocrlf = input
    editor   = nvim
    pager    = less -FX

[init]
    defaultBranch = main

[pull]
    rebase = true

[push]
    autoSetupRemote = true

[rebase]
    autoStash = true

[merge]
    conflictstyle = diff3

[diff]
    algorithm = histogram

[alias]
    st   = status
    co   = checkout
    br   = branch
    lg   = log --oneline --graph --decorate --all
    undo = reset --soft HEAD~1
    wip  = commit -am "wip: work in progress"

[color]
    ui = auto
