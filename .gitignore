# HarnessOS — gitignore

# Build artifacts
out/
work/
*.iso
*.img

# Installer copy injected into airootfs during build (generated, not source)
archiso/airootfs/usr/local/lib/harness/installer/

# Galago (easter egg) copy injected into airootfs during build (generated, not source)
archiso/airootfs/usr/local/share/harness/easter-egg/galago/

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/
dist/
build/

# Node
node_modules/
.npm/

# Editor
.idea/
*.swp
*.swo
.vscode/

# OS
.DS_Store
Thumbs.db

# Secrets
.env
*.pem
*.key

# Easter egg source photo (baked copy lives in airootfs/)
foto.png

# Raw screenshot sources at repo root (copies go to docs/screenshots/)
Captura*.png

# Raw WhatsApp photos (curated copies go to docs/screenshots/)
img/

# Pacman repo database (generated)
packages/repo/*.db*
packages/repo/*.files*
packages/repo/*.pkg.tar.*
